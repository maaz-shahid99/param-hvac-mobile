<!-- API <= 30 : exclude all app data from auto-backup (belt-and-braces with
     android:allowBackup="false"). -->
<full-backup-content>
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
</full-backup-content>
